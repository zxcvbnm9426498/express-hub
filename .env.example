# Frontend direct API base URL. Leave empty to use Vite /api proxy.
VITE_API_BASE_URL=

# Vite dev proxy target.
VITE_PROXY_TARGET=http://localhost:8787

# Backend runtime
PORT=8787
DB_PATH=data/shipment-hub.db

# Kuaidi100 signed poll API (optional; if empty, fallback query API is used)
KD100_KEY=
KD100_CUSTOMER=
KD100_PHONE=
KD100_FROM=
KD100_TO=
